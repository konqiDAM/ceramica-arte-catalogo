---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ObraCard from "../components/ObraCard.astro";
import { site } from "../data/site";

const obras = (await getCollection("obras")).sort(
  (a, b) => a.data.orden - b.data.orden,
);
const destacadas = obras.filter((o) => o.data.destacada).slice(0, 6);
const totalPorCategoria = obras.reduce<Record<string, number>>((acc, o) => {
  acc[o.data.categoria] = (acc[o.data.categoria] ?? 0) + 1;
  return acc;
}, {});
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Hecho a mano · Piezas únicas</p>
        <h1>{site.tagline}</h1>
        <p class="lead">
          {site.description} Descubre el catálogo del taller: cerámica utilitaria,
          escultura y obra de arte, cada pieza modelada y esmaltada a mano.
        </p>
        <div class="hero-cta">
          <a href="/catalogo" class="btn btn-primary">Ver catálogo</a>
          <a href="/sobre" class="btn btn-ghost">Conocer el taller</a>
        </div>
      </div>
      <div class="hero-media">
        <img src="/images/pieza-1.svg" alt="Pieza de cerámica destacada" width="500" height="500" />
        <img src="/images/pieza-6.svg" alt="Escultura destacada" width="500" height="500" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selección</p>
          <h2>Piezas destacadas</h2>
        </div>
        <a href="/catalogo" class="see-all">Ver todo el catálogo →</a>
      </div>
      <div class="grid">
        {
          destacadas.map((o) => (
            <ObraCard
              slug={o.id}
              titulo={o.data.titulo}
              categoria={o.data.categoria}
              descripcion={o.data.descripcion}
              imagen={o.data.imagen}
              disponible={o.data.disponible}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container categorias">
      <div class="cat-intro">
        <p class="eyebrow">Explora</p>
        <h2>Por categoría</h2>
        <p class="lead">
          Desde piezas para el día a día hasta obra puramente artística.
        </p>
      </div>
      <div class="cat-grid">
        {
          Object.entries(totalPorCategoria).map(([cat, n]) => (
            <a href={`/catalogo#${cat.toLowerCase()}`} class="cat-card">
              <h3>{cat}</h3>
              <span>{n} {n === 1 ? "pieza" : "piezas"}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container center">
      <h2>¿Te interesa una pieza?</h2>
      <p class="lead mx-auto">
        Trabajamos también por encargo. Escríbenos y hablamos sobre tu idea.
      </p>
      <a href="/contacto" class="btn btn-primary">Contactar</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: clamp(3rem, 7vw, 6rem) 0 clamp(2rem, 5vw, 4rem); }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-cta { display: flex; gap: 1rem; margin-top: 1.8rem; flex-wrap: wrap; }
  .hero-media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .hero-media img {
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .hero-media img:first-child { margin-top: 2rem; }
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    gap: 1rem;
  }
  .see-all { font-weight: 600; white-space: nowrap; }
  .categorias { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 2.5rem; align-items: center; }
  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; }
  .cat-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.6rem 1.4rem;
    color: var(--ink);
    transition: 0.2s;
  }
  .cat-card:hover { border-color: var(--clay); transform: translateY(-3px); }
  .cat-card h3 { margin-bottom: 0.2rem; }
  .cat-card span { color: var(--muted); font-size: 0.9rem; }
  .cta-band h2 { margin-bottom: 0.5rem; }
  .cta-band .btn { margin-top: 1.5rem; }
  @media (max-width: 820px) {
    .hero-inner, .categorias { grid-template-columns: 1fr; }
    .hero-media img:first-child { margin-top: 0; }
  }
</style>
